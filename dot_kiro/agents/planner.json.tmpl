{{- $k := .kiro -}}
{{- $mcps := list "grafana_non_prod" "atlassian" "aws" "gitlab" "chrome" -}}
{{- $tool_groups := list "read_only" -}}
{{- $tool_setting_layers := list "base" "write_docs" -}}
{{- $toolsSettings := dict -}}
{{- range $tool_setting_layers -}}
{{-   $toolsSettings = mustMergeOverwrite $toolsSettings (index $k.tool_settings .) -}}
{{- end -}}
{{- $servers := dict -}}
{{- $tools := list -}}
{{- range $group := $tool_groups -}}
{{-   $tools = concat $tools (index $k.base_tools $group) -}}
{{- end -}}
{{- range $mcps -}}
{{-   $mcp := index $k.mcp_servers . -}}
{{-   $config := dict -}}
{{-   if hasKey $mcp "config" -}}
{{-     $config = $mcp.config -}}
{{-   else if eq $.chezmoi.os "windows" -}}
{{-     $config = $mcp.config_windows -}}
{{-   else -}}
{{-     $config = $mcp.config_linux -}}
{{-   end -}}
{{-   $_ := set $servers $mcp.name $config -}}
{{-   range $group := $tool_groups -}}
{{-     range $tool := index $mcp.allowed_tools $group -}}
{{-       $tools = append $tools (printf "@%s/%s" $mcp.name $tool) -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- $config := dict
    "name" "planner"
    "description" "Specialized planning agent that helps break down ideas into implementation plans"
    "prompt" "file://./planner.md"
    "mcpServers" $servers
    "tools" (list "*")
    "toolsSettings" $toolsSettings
    "toolAliases" (dict)
    "allowedTools" $tools
    "resources" $k.resources
    "hooks" (dict)
    "includeMcpJson" false
    "model" nil
    "welcomeMessage" "Read only planning agent"
-}}
{{ toPrettyJson $config }}
